#!/usr/bin/env bash
# bin/build — Build a NixOS configuration without deploying.
#
# Usage: bin/build [--dev] [<HOST>]
#
# ## RFC 2119 Functional Requirements
#
# 1. The script MUST accept an optional <HOST> positional argument
#    matching a nixosConfigurations key in flake.nix.
# 2. The script MUST default <HOST> to the flake config name matching
#    the current machine's hostname when no argument is provided, by
#    looking up the hostname field in hosts.nix.
# 3. The script MUST validate <HOST> exists in hosts.nix. On failure,
#    the script MUST print the list of known hosts and exit non-zero.
# 4. The script MUST support a --dev flag that adds --override-input
#    for both keystone (.submodules/keystone) and agenix-secrets
#    (agenix-secrets/) local submodule paths.
# 5. When --dev is used, the script MUST verify both submodule
#    directories exist before proceeding.
# 6. The script MUST NOT require sudo or elevated privileges.
# 7. The script MUST NOT apply any configuration to any system
#    (no nixos-rebuild switch/boot).
# 8. The script SHOULD produce a ./result symlink on success.
# 9. The script SHOULD print the resolved host name and dev mode
#    status before building.
#
# ## Caching Workflow
#
# Build on workstation or ocean first — their attic binary cache push
# (keystone.binaryCache.push) populates the shared cache. Low-power
# machines then pull cached derivations during their deploy.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$(dirname "$SCRIPT_DIR")" && pwd -P)"
HOSTS_NIX="$REPO_ROOT/hosts.nix"

DEV=false
HOST=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --dev) DEV=true; shift ;;
    -*) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
    *) HOST="$1"; shift ;;
  esac
done

# Resolve HOST from current hostname if not provided
if [[ -z "$HOST" ]]; then
  CURRENT=$(hostname)
  HOST=$(nix eval -f "$HOSTS_NIX" --raw \
    --apply "hosts: let m = builtins.filter (k: (builtins.getAttr k hosts).hostname == \"$CURRENT\") (builtins.attrNames hosts); in if m == [] then \"\" else builtins.head m")
  if [[ -z "$HOST" ]]; then
    echo "Error: No hosts.nix entry with hostname '$CURRENT'." >&2
    echo "Specify HOST explicitly: bin/build <HOST>" >&2
    exit 1
  fi
fi

# Validate HOST exists in hosts.nix
if ! nix eval -f "$HOSTS_NIX" "$HOST" --json >/dev/null 2>&1; then
  echo "Error: Unknown host '$HOST'." >&2
  echo "Known hosts:" >&2
  nix eval -f "$HOSTS_NIX" --apply 'h: builtins.concatStringsSep "\n  " (builtins.attrNames h)' --raw >&2
  echo >&2
  exit 1
fi

# Build --dev override args
OVERRIDE_ARGS=()
if [[ "$DEV" == true ]]; then
  KEYSTONE_PATH="$REPO_ROOT/.submodules/keystone"
  SECRETS_PATH="$REPO_ROOT/agenix-secrets"
  [[ -d "$KEYSTONE_PATH" ]] || { echo "Error: Missing $KEYSTONE_PATH" >&2; exit 1; }
  [[ -d "$SECRETS_PATH" ]] || { echo "Error: Missing $SECRETS_PATH" >&2; exit 1; }
  OVERRIDE_ARGS+=(--override-input keystone "path:$KEYSTONE_PATH")
  OVERRIDE_ARGS+=(--override-input agenix-secrets "path:$SECRETS_PATH")
  echo "Dev mode: using local keystone + agenix-secrets"
fi

echo "Building $HOST..."
nix build "$REPO_ROOT#nixosConfigurations.$HOST.config.system.build.toplevel" \
  "${OVERRIDE_ARGS[@]}"
echo "Build complete for $HOST"
