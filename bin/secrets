#!/usr/bin/env bash
# Commit and push agenix-secrets changes, update flake lock, and commit in root repo.
#
# Usage:
#   ./bin/secrets "chore: rekey all secrets"
#   ./bin/secrets                              # auto-generates commit message

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$(dirname "$SCRIPT_DIR")" && pwd -P)"
SECRETS_PATH="$REPO_ROOT/agenix-secrets"

COMMIT_MSG="${1:-"chore: update agenix secrets"}"

# Step 1: Commit agenix-secrets changes if any
if ! git -C "$SECRETS_PATH" diff --quiet || ! git -C "$SECRETS_PATH" diff --cached --quiet; then
  echo "Committing agenix-secrets changes..."
  git -C "$SECRETS_PATH" add -A
  git -C "$SECRETS_PATH" commit -m "$COMMIT_MSG"
else
  echo "No uncommitted changes in agenix-secrets"
fi

# Step 2: Push agenix-secrets if ahead of remote
LOCAL=$(git -C "$SECRETS_PATH" rev-parse HEAD)
REMOTE=$(git -C "$SECRETS_PATH" rev-parse @{upstream} 2>/dev/null || echo "")
if [ "$LOCAL" != "$REMOTE" ]; then
  echo "Pushing agenix-secrets to remote..."
  git -C "$SECRETS_PATH" push
else
  echo "agenix-secrets already up to date with remote"
fi

# Step 3: Update flake.lock for agenix-secrets input
echo "Updating flake.lock for agenix-secrets input..."
nix flake update agenix-secrets --flake "$REPO_ROOT"

# Step 4: Commit submodule ref + flake.lock in root repo
NEEDS_COMMIT=false

if ! git -C "$REPO_ROOT" diff --quiet agenix-secrets; then
  git -C "$REPO_ROOT" add agenix-secrets
  NEEDS_COMMIT=true
fi

if ! git -C "$REPO_ROOT" diff --quiet flake.lock; then
  git -C "$REPO_ROOT" add flake.lock
  NEEDS_COMMIT=true
fi

if [ "$NEEDS_COMMIT" = true ]; then
  ROOT_MSG="chore(agenix-secrets): relock flake input - $COMMIT_MSG"
  git -C "$REPO_ROOT" commit -m "$ROOT_MSG"
  echo "Created commit: $ROOT_MSG"
else
  echo "No changes to commit in root repo"
fi

echo "Done."
